{
  "name": "Speaker Queue Manager",
  "version": "1.0.0",
  "description": "Manage speaker queues and track speaking time in Zoom meetings",
  "developer": {
    "name": "Michelle Gallagher",
    "website_url": "https://queuetime.netlify.app",
    "privacy_policy_url": "https://queuetime.netlify.app/privacy-policy.html",
    "terms_of_use_url": "https://queuetime.netlify.app/terms-of-service.html"
  },
  "app_type": "zoomapp",
  "scopes": [
    "listParticipants",
    "getMeetingParticipants",
    "getWebinarParticipants",
    "onParticipantChange",
    "onActiveSpeakerChange",
    "onWebinarParticipantChange"
  ],
  "features": {
    "native_sdk_version": "0.16.0",
    "in_client": true,
    "supports_breakout_rooms": false
  },
  "home_url": "https://queuetime.netlify.app",
  "redirect_urls": [
    "https://queuetime.netlify.app/auth"
  ],
  "context": {
    "in_meeting": true,
    "in_webinar": true,
    "in_chat": false,
    "in_phone": false
  },
  "size_constraints": {
    "min_width": 320,
    "max_width": 1000,
    "min_height": 400,
    "max_height": 800
  }
}